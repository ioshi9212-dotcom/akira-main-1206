# Railway / local configuration for akira-main-1206

# Railway volume mount path.
# In Railway: Service -> Volumes -> Mount Path = /data
RAILWAY_VOLUME_MOUNT_PATH=/data

# Public Railway domain without https:// is okay.
# The app will normalize it to https://...
RAILWAY_PUBLIC_DOMAIN=akira-main-1206-production.up.railway.app

# Optional explicit public URL. Use this if the Railway domain changes or you add a custom domain.
# PUBLIC_BASE_URL=https://akira-main-1206-production.up.railway.app

# Default session used by the short GPT Actions endpoint /api/v1/turn/context
DEFAULT_SESSION_ID=main-1206-default

# Project label returned in state and schemas
PROJECT_SLUG=akira-main-1206

# Start scene file inside the repository
START_SCENE_FILE=data/scenes/start_scene.md

# Local-only fallback. Usually do not set this on Railway if the volume is mounted at /data.
# DATA_DIR=./data
